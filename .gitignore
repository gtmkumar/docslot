# ─────────────────────────────────────────────────────────────
# DocSlot — root .gitignore
# Covers: .NET, Python, Node/React (Vite), IDE, OS, secrets
# ─────────────────────────────────────────────────────────────

# ── OS ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editors / IDE ────────────────────────────────────────────
.vs/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.swp
*.swo
*~

# ── Secrets / env ────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.pfx
*.p12
secrets.json
appsettings.*.Local.json
appsettings.Development.json

# ─────────────────────────────────────────────────────────────
# .NET  (backend/mediq)
# ─────────────────────────────────────────────────────────────
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
[Dd]ebugPublic/
[Rr]eleases/
x64/
x86/
build/
bld/
[Ll]og/
[Ll]ogs/
*.dll
*.exe
*.pdb
*.cache
*.user
project.lock.json
project.fragment.lock.json
artifacts/
.nuget/
packages/
!packages/build/
*.nupkg
*.snupkg
TestResults/
[Tt]est[Rr]esult*/
coverage*.json
coverage*.xml
coverage*.info
.sonarqube/
msbuild.log
msbuild.err
msbuild.wrn
StyleCop.Cache

# ─────────────────────────────────────────────────────────────
# Python  (ai_service)
# ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pytype/
.dmypy.json
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.ipynb_checkpoints/
# ML / model artifacts
*.ckpt
*.pt
*.bin
*.onnx

# ─────────────────────────────────────────────────────────────
# Node / React  (frontend)
# ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/install-state.gz
dist/
dist-ssr/
build/
.vite/
*.local
# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
# TypeScript build info
*.tsbuildinfo
# Test / coverage
coverage/
.nyc_output/
playwright-report/
test-results/
.cache/
.parcel-cache/
# Storybook
storybook-static/

# ─────────────────────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────────────────────
*.log
tmp/
temp/
.docslot-tmp/
