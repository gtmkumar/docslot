{
  "Jwt": {
    "Issuer": "docslot-platform",
    "Audience": "docslot-clients",
    "SigningKey": "ZGV2LW9ubHktc2lnbmluZy1rZXktcmVwbGFjZS1pbi1wcm9kdWN0aW9uLTI1Ni1iaXQh"
  },
  "ForwardedHeaders": {
    "_comment": "STRICT default-deny: with KnownProxies + KnownNetworks empty, X-Forwarded-For is IGNORED and the edge rate limiter partitions on the raw socket IP (no behavior change). When deployed behind a load balancer / reverse proxy, populate KnownProxies with the proxy/LB IP(s) (and/or KnownNetworks with CIDR ranges) to make the limiter trust X-Forwarded-For for per-client-IP limiting.",
    "ForwardLimit": 1,
    "KnownProxies": [],
    "KnownNetworks": []
  },
  "ReverseProxy": {
    "Routes": {
      "auth-login": {
        "ClusterId": "platform-api-cluster",
        "AuthorizationPolicy": "anonymous",
        "Order": 1,
        "Match": {
          "Path": "/api/v1/auth/login",
          "Methods": [ "POST" ]
        }
      },
      "auth-refresh": {
        "ClusterId": "platform-api-cluster",
        "AuthorizationPolicy": "anonymous",
        "Order": 1,
        "Match": {
          "Path": "/api/v1/auth/refresh",
          "Methods": [ "POST" ]
        }
      },
      "oauth-token": {
        "ClusterId": "platform-api-cluster",
        "AuthorizationPolicy": "anonymous",
        "Order": 1,
        "Match": {
          "Path": "/api/v1/oauth/token",
          "Methods": [ "POST" ]
        }
      },
      "oauth-revoke": {
        "ClusterId": "platform-api-cluster",
        "AuthorizationPolicy": "anonymous",
        "Order": 1,
        "Match": {
          "Path": "/api/v1/oauth/revoke",
          "Methods": [ "POST" ]
        }
      },
      "whatsapp-webhook": {
        "ClusterId": "platform-api-cluster",
        "AuthorizationPolicy": "anonymous",
        "Order": 1,
        "Match": {
          "Path": "/api/v1/whatsapp/webhook",
          "Methods": [ "GET", "POST" ]
        }
      },
      "referral-shortcode": {
        "ClusterId": "platform-api-cluster",
        "AuthorizationPolicy": "anonymous",
        "Order": 1,
        "Match": {
          "Path": "/api/v1/ref/{shortCode}",
          "Methods": [ "GET" ]
        }
      },
      "platform-api": {
        "ClusterId": "platform-api-cluster",
        "AuthorizationPolicy": "default",
        "Order": 100,
        "Match": {
          "Path": "/api/v1/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "platform-api-cluster": {
        "Destinations": {
          "primary": {
            "Address": "https+http://mediq-api"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
